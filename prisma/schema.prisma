generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Video {
  id            String   @id @default(cuid())
  title         String
  description   String?
  storagePath   String
  thumbnailPath String?
  transcript    String?
  duration      Int?     // seconds
  sourceUrl     String?  // original YouTube URL if imported
  niche         String   @default("general")
  tone          String   @default("professional")
  status        VideoStatus @default(PENDING)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  platformContents PlatformContent[]
  scheduledJobs    ScheduledJob[]
  publishLogs      PublishLog[]
}

enum VideoStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model PlatformContent {
  id          String   @id @default(cuid())
  videoId     String
  platform    Platform
  title       String?
  caption     String?
  hashtags    String[] // array of hashtag strings
  description String?
  customData  Json?    // platform-specific extra fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, platform])
}

enum Platform {
  YOUTUBE
  INSTAGRAM
  TIKTOK
  FACEBOOK
  TWITTER
}

model ScheduledJob {
  id          String      @id @default(cuid())
  videoId     String
  platform    Platform
  scheduledAt DateTime
  status      JobStatus   @default(PENDING)
  executedAt  DateTime?
  errorMsg    String?
  retryCount  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

enum JobStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
  CANCELLED
}

model PublishLog {
  id           String   @id @default(cuid())
  videoId      String
  platform     Platform
  status       JobStatus
  platformPostId String?
  errorMsg     String?
  publishedAt  DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model OAuthToken {
  id           String   @id @default(cuid())
  platform     Platform @unique
  accessToken  String   // encrypted
  refreshToken String?  // encrypted
  expiresAt    DateTime?
  scope        String?
  accountId    String?
  accountName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
